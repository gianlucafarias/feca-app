EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3001
# Places API (New) — autocompletado de ciudad en onboarding (restringir la clave por app en Google Cloud)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Opcional: si no lo ponés, se calcula desde EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID al hacer prebuild.
# Debe ser com.googleusercontent.apps.<mismo prefijo que el client id iOS sin el sufijo .apps.googleusercontent.com>
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
